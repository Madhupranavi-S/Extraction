# =============================================================
# STAGE 1 — FACE DETECTOR CONFIG (thermal_detector.pt)
# =============================================================
FACE_CONF_THRESH = 0.25
FACE_IMG_SIZE    = 320   # imgsz fed to the face model
ZOOM_PAD_FRAC    = 0.25  # pad the face box by this fraction on each side before crop
ZOOM_SCALE       = 2.0   # upscale the padded crop by this factor before stage 2

# =============================================================
# STAGE 2 — CANTHUS MODEL CONFIG (detect.pt)
# =============================================================
# detect.pt was TRAINED on SAHI-sliced crops. Here, instead of running it
# on the full frame, we run it on the zoomed-in face crop produced by
# stage 1 — same model, same classes, same logic as before, just fed a
# cropped/zoomed region instead of the full frame.
#   0 -> left_inner_canthus
#   1 -> right_inner_canthus
CLASS_LEFT  = 0
CLASS_RIGHT = 1
CONF_THRESH = 0.25
IMG_SIZE    = 320   # set to whatever size detect.pt was trained/eval'd at

def _preprocess(img_bgr: np.ndarray) -> np.ndarray:
    """
    Match training pipeline.
    Training used IronRed images directly.
    """
    return img_bgr

def _detect_face(face_model, bgr: np.ndarray):
    """
    Run the stage-1 face model on the full frame.
    Returns face_box (x1, y1, x2, y2) in full-frame pixel coords,
    or None if no face found. Picks the highest-confidence box.
    """
    results = face_model(bgr, imgsz=FACE_IMG_SIZE, conf=FACE_CONF_THRESH,
                          verbose=False)[0]

    best_box  = None
    best_conf = 0.0

    if results.boxes is not None and len(results.boxes) > 0:
        boxes = results.boxes.xyxy.cpu().numpy()
        confs = results.boxes.conf.cpu().numpy()
        for box, conf in zip(boxes, confs):
            if conf > best_conf:
                best_conf = float(conf)
                best_box  = (int(box[0]), int(box[1]), int(box[2]), int(box[3]))

    return best_box

def _crop_and_zoom(bgr: np.ndarray, face_box):
    """
    Pad the face box, crop it from the full frame, and upscale
    (zoom in) before feeding to the stage-2 canthus model.

    Returns (zoomed_crop_bgr, crop_origin, scale) where:
      - crop_origin = (x1, y1) of the padded crop in full-frame coords
        (i.e. where the crop's pixel (0,0) sits in the full frame)
      - scale = factor to divide zoomed-crop coords by to get back to
        the *padded crop's* coords (then add crop_origin for full-frame)
    """
    h, w = bgr.shape[:2]
    x1, y1, x2, y2 = face_box

    box_w = x2 - x1
    box_h = y2 - y1
    pad_x = int(box_w * ZOOM_PAD_FRAC)
    pad_y = int(box_h * ZOOM_PAD_FRAC)

    cx1 = max(0, x1 - pad_x)
    cy1 = max(0, y1 - pad_y)
    cx2 = min(w, x2 + pad_x)
    cy2 = min(h, y2 + pad_y)

    crop = bgr[cy1:cy2, cx1:cx2]
    if crop.size == 0:
        return None, (cx1, cy1), 1.0

    zoomed = cv2.resize(crop, None, fx=ZOOM_SCALE, fy=ZOOM_SCALE,
                         interpolation=cv2.INTER_LINEAR)

    return zoomed, (cx1, cy1), ZOOM_SCALE

def _single_stage_detect(model, bgr: np.ndarray):
    """
    UNCHANGED from the original single-stage script.
    Run the canthus model directly on whatever image is passed in
    (here: the zoomed face crop, instead of the full frame).
    Returns (left_pt, right_pt, left_conf, right_conf) in the
    *input image's own* pixel coords. Either point may be None if
    that class wasn't found — both points are NOT required.
    """
    prepped = _preprocess(bgr)
    results = model(prepped, imgsz=IMG_SIZE, conf=CONF_THRESH, verbose=False)[0]

    left_pt  = None
    right_pt = None
    left_conf  = 0.0
    right_conf = 0.0

    if results.boxes is not None and len(results.boxes) > 0:
        boxes = results.boxes.xyxy.cpu().numpy()
        clss  = results.boxes.cls.cpu().numpy().astype(int)
        confs = results.boxes.conf.cpu().numpy()

        for box, cls_id, conf in zip(boxes, clss, confs):
            cx = float((box[0] + box[2]) / 2.0)
            cy = float((box[1] + box[3]) / 2.0)

            if cls_id == CLASS_LEFT and conf > left_conf:
                left_pt   = (cx, cy)
                left_conf = float(conf)
            elif cls_id == CLASS_RIGHT and conf > right_conf:
                right_pt   = (cx, cy)
                right_conf = float(conf)

    return left_pt, right_pt, left_conf, right_conf

def _two_stage_detect(face_model, canthus_model, bgr: np.ndarray):
    """
    Stage 1: detect face on the full frame.
    Stage 2: crop + zoom into the face region, run the (unchanged)
             canthus detector on that crop, then map the resulting
             points back to full-frame pixel coords.

    Returns (left_pt, right_pt, left_conf, right_conf, face_box) all
    in full-frame pixel coords. face_box is None if stage 1 found
    nothing, in which case stage 2 is skipped entirely.
    """
    face_box = _detect_face(face_model, bgr)
    if face_box is None:
        return None, None, 0.0, 0.0, None

    zoomed, (ox, oy), scale = _crop_and_zoom(bgr, face_box)
    if zoomed is None:
        return None, None, 0.0, 0.0, face_box

    left_pt, right_pt, left_conf, right_conf = _single_stage_detect(
        canthus_model, zoomed)

    # Map zoomed-crop coords -> padded-crop coords -> full-frame coords
    if left_pt is not None:
        lx, ly = left_pt
        left_pt = (lx / scale + ox, ly / scale + oy)
    if right_pt is not None:
        rx, ry = right_pt
        right_pt = (rx / scale + ox, ry / scale + oy)

    return left_pt, right_pt, left_conf, right_conf, face_box

