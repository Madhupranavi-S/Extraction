# =============================================================
# SINGLE-STAGE MODEL CONFIG
# =============================================================
# best.pt was TRAINED on SAHI-sliced crops. At inference time we
# now ALSO slice the full frame with SAHI (same slice geometry the
# model was trained on) instead of running it on the whole frame.
# It detects two classes directly:
#   0 -> left_inner_canthus
#   1 -> right_inner_canthus
CLASS_LEFT  = 0
CLASS_RIGHT = 1
CONF_THRESH = 0.25
IMG_SIZE    = 320   # imgsz fed to the model per-slice

# --- SAHI slicing geometry ---
# Tuned for subjects at ~2-3m on a typical handheld thermal camera
# (canthus is only a handful of pixels wide in the full frame at this
# range, so slices need to be small enough that the canthus occupies
# a meaningful fraction of each tile — see SAHI_UPSCALE below too).
# If best.pt was trained on a specific crop size, prefer that instead
# (override via --slice-w/--slice-h).
SAHI_SLICE_H = 72
SAHI_SLICE_W = 96
SAHI_OVERLAP = 0.35         # fractional overlap between adjacent slices
                            # (higher than usual so a canthus sitting
                            # near a tile border is fully captured in
                            # at least one neighbouring slice)
SAHI_MERGE_IOU = 0.3        # IoU threshold for de-duplicating boxes
                            # that straddle two overlapping slices
SAHI_UPSCALE = 2.0          # each slice is upscaled by this factor
                            # before inference, recovering effective
                            # resolution for small/far targets without
                            # needing impractically tiny slices


def _preprocess(img_bgr: np.ndarray) -> np.ndarray:
    """
    Match training pipeline.
    Training used IronRed images directly — no CLAHE, no extra
    contrast steps. Keep this identical for every slice we feed
    the model so inference matches training distribution.
    """
    return img_bgr


def _make_slices(width: int, height: int):
    """
    Generate (x1, y1, x2, y2) slice boxes covering the full frame,
    with overlap, clamped to the frame edges. Mirrors how the
    training crops were generated (last slice in each axis is
    pulled back from the far edge rather than running off frame).
    """
    stride_x = max(1, int(SAHI_SLICE_W * (1 - SAHI_OVERLAP)))
    stride_y = max(1, int(SAHI_SLICE_H * (1 - SAHI_OVERLAP)))

    xs = list(range(0, max(width - SAHI_SLICE_W, 0) + 1, stride_x))
    ys = list(range(0, max(height - SAHI_SLICE_H, 0) + 1, stride_y))
    if not xs or xs[-1] != max(width - SAHI_SLICE_W, 0):
        xs.append(max(width - SAHI_SLICE_W, 0))
    if not ys or ys[-1] != max(height - SAHI_SLICE_H, 0):
        ys.append(max(height - SAHI_SLICE_H, 0))

    slices = []
    for y1 in ys:
        y2 = min(y1 + SAHI_SLICE_H, height)
        y1 = max(0, y2 - SAHI_SLICE_H)
        for x1 in xs:
            x2 = min(x1 + SAHI_SLICE_W, width)
            x1 = max(0, x2 - SAHI_SLICE_W)
            slices.append((x1, y1, x2, y2))
    return slices


def _iou(box_a, box_b) -> float:
    ax1, ay1, ax2, ay2 = box_a
    bx1, by1, bx2, by2 = box_b

    inter_x1 = max(ax1, bx1)
    inter_y1 = max(ay1, by1)
    inter_x2 = min(ax2, bx2)
    inter_y2 = min(ay2, by2)

    inter_w = max(0.0, inter_x2 - inter_x1)
    inter_h = max(0.0, inter_y2 - inter_y1)
    inter_area = inter_w * inter_h
    if inter_area <= 0:
        return 0.0

    area_a = max(0.0, ax2 - ax1) * max(0.0, ay2 - ay1)
    area_b = max(0.0, bx2 - bx1) * max(0.0, by2 - by1)
    union = area_a + area_b - inter_area
    if union <= 0:
        return 0.0
    return inter_area / union


def _nms_merge(dets):
    """
    Greedy NMS over a list of (box_xyxy, conf) for a single class.
    Slices overlap by SAHI_OVERLAP, so the same real-world canthus
    can be detected in 2+ neighbouring slices — this collapses
    those duplicates down to the single highest-confidence box.
    """
    if not dets:
        return []
    dets = sorted(dets, key=lambda d: d[1], reverse=True)
    kept = []
    used = [False] * len(dets)

    for i, (box_i, conf_i) in enumerate(dets):
        if used[i]:
            continue
        kept.append((box_i, conf_i))
        for j in range(i + 1, len(dets)):
            if used[j]:
                continue
            box_j, _ = dets[j]
            if _iou(box_i, box_j) > SAHI_MERGE_IOU:
                used[j] = True
    return kept


def _single_stage_detect(model, bgr: np.ndarray):
    """
    SAHI-style sliced inference for the single-stage canthus model.

    The frame is cut into overlapping SAHI_SLICE_H x SAHI_SLICE_W
    tiles (matching the geometry best.pt was trained on). Each tile
    is run through the detector independently at imgsz=IMG_SIZE,
    conf=CONF_THRESH, and every detection is mapped back into
    full-frame pixel coordinates. Detections from overlapping tiles
    are then merged per-class with NMS, and the single highest
    confidence box per class is returned.

    Returns (left_pt, right_pt, left_conf, right_conf) in full-frame
    pixel coords. Either point may be None if that class wasn't found
    anywhere in the frame — both points are NOT required.
    """
    prepped = _preprocess(bgr)
    h, w = prepped.shape[:2]

    left_dets  = []  # list of (box_xyxy_fullframe, conf)
    right_dets = []

    for (x1, y1, x2, y2) in _make_slices(w, h):
        patch = prepped[y1:y2, x1:x2]
        if patch.size == 0:
            continue

        # Upscale the slice before inference. At long range the
        # canthus is only a few pixels wide even within a small slice
        # — enlarging the patch (without changing what it depicts)
        # gives the model's internal stride/downsampling stages more
        # effective resolution to work with, recovering detail that
        # would otherwise be lost. This does NOT add real information,
        # but it avoids losing the little information that exists to
        # the network's own downsampling.
        if SAHI_UPSCALE != 1.0:
            patch_in = cv2.resize(
                patch, None, fx=SAHI_UPSCALE, fy=SAHI_UPSCALE,
                interpolation=cv2.INTER_CUBIC)
        else:
            patch_in = patch

        results = model(patch_in, imgsz=IMG_SIZE, conf=CONF_THRESH,
                         verbose=False)[0]

        if results.boxes is None or len(results.boxes) == 0:
            continue

        boxes = results.boxes.xyxy.cpu().numpy()
        clss  = results.boxes.cls.cpu().numpy().astype(int)
        confs = results.boxes.conf.cpu().numpy()

        for box, cls_id, conf in zip(boxes, clss, confs):
            # box is in upscaled-patch coords -> divide back down to
            # original slice-local coords -> then add slice offset to
            # land in full-frame coords.
            full_box = (
                float(box[0] / SAHI_UPSCALE + x1),
                float(box[1] / SAHI_UPSCALE + y1),
                float(box[2] / SAHI_UPSCALE + x1),
                float(box[3] / SAHI_UPSCALE + y1),
            )
            if cls_id == CLASS_LEFT:
                left_dets.append((full_box, float(conf)))
            elif cls_id == CLASS_RIGHT:
                right_dets.append((full_box, float(conf)))

    left_dets  = _nms_merge(left_dets)
    right_dets = _nms_merge(right_dets)

    left_pt  = None
    right_pt = None
    left_conf  = 0.0
    right_conf = 0.0

    if left_dets:
        (lx1, ly1, lx2, ly2), left_conf = max(left_dets, key=lambda d: d[1])
        left_pt = (float((lx1 + lx2) / 2.0), float((ly1 + ly2) / 2.0))

    if right_dets:
        (rx1, ry1, rx2, ry2), right_conf = max(right_dets, key=lambda d: d[1])
        right_pt = (float((rx1 + rx2) / 2.0), float((ry1 + ry2) / 2.0))

    return left_pt, right_pt, left_conf, right_conf

