    if not os.path.exists(LOG_FILE):
        with open(LOG_FILE, 'w', newline='') as f:
            writer = csv.writer(f)
            writer.writerow([
                "timestamp",
                "lc_raw", "rc_raw", "canthus_raw",
                "t_ambient", "humidity",
                "lc_corrected", "rc_corrected", "canthus_corrected",
                "lc_conf", "rc_conf", "sides_detected",
                "lc_rc_diff",
                "ambient_source", "classification",
                "holding", "fever_streak"
            ])

def log_reading(lc_raw, rc_raw,
                t_amb, humidity,
                lc_corr, rc_corr,
                lc_conf, rc_conf, sides_detected,
                label, ambient_source,
                holding, streak):
    canthus_raw  = max(lc_raw,  rc_raw)
    canthus_corr = max(lc_corr, rc_corr)
    diff_str     = f"{abs(lc_raw-rc_raw):.2f}" if sides_detected == "both" else "N/A"
    with open(LOG_FILE, 'a', newline='') as f:
        writer = csv.writer(f)
        writer.writerow([
            datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            f"{lc_raw:.2f}",   f"{rc_raw:.2f}",
            f"{canthus_raw:.2f}",
            f"{t_amb:.2f}",
            f"{humidity:.1f}" if humidity else "N/A",
            f"{lc_corr:.2f}",  f"{rc_corr:.2f}",
            f"{canthus_corr:.2f}",
            f"{lc_conf:.3f}",  f"{rc_conf:.3f}",
            sides_detected,
            diff_str,
            ambient_source, label,
            "yes" if holding else "no",
            str(streak)
        ])

# =============================================================
# DEBUG DISPLAY BUILDER
# =============================================================
def build_debug_display(frozen_frame, temps_avg, bgr_input,
                        face_detected, sides_detected, holding,
                        lc_raw, rc_raw,
                        lc_corr, rc_corr,
                        lc_conf, rc_conf,
                        t_amb, humidity,
                        label, color,
                        lc_xy, rc_xy,
                        ambient_source,
                        streak):
    h, w = temps_avg.shape

    # Panel 1 — IronRed thermal
    palette = g.Palette.IronRed
    opts    = g.PaletteOptions(auto_range=True)
    rgb     = g.apply_palette(frozen_frame.y16, palette, opts)
    panel1  = cv2.cvtColor(rgb, cv2.COLOR_RGB2BGR)
    panel1  = cv2.resize(panel1, (w * 2, h * 2))

    # Panel 2 — BGR fed to the model
    panel2  = cv2.resize(bgr_input, (w * 2, h * 2))
    cv2.putText(panel2,
                f"LC conf:{lc_conf:.2f}  RC conf:{rc_conf:.2f}",
                (10, 25), cv2.FONT_HERSHEY_SIMPLEX,
                0.5, (200, 200, 200), 1)

    if face_detected:
        lc_x, lc_y = lc_xy
        rc_x, rc_y = rc_xy
        lc_x = int(lc_x) if lc_x is not None else None
        lc_y = int(lc_y) if lc_y is not None else None
        rc_x = int(rc_x) if rc_x is not None else None
        rc_y = int(rc_y) if rc_y is not None else None

        for panel in (panel1, panel2):
            if lc_x is not None:
                cv2.circle(panel, (lc_x*2, lc_y*2), 8, (0, 255, 255), 2)
                cv2.putText(panel,
                            f"LC r:{lc_raw:.1f} c:{lc_corr:.1f}",
                            (lc_x*2 + 8, lc_y*2 - 8),
                            cv2.FONT_HERSHEY_SIMPLEX,
                            0.4, (0, 255, 255), 1)
            if rc_x is not None:
                cv2.circle(panel, (rc_x*2, rc_y*2), 8, (0, 255, 255), 2)
                cv2.putText(panel,
                            f"RC r:{rc_raw:.1f} c:{rc_corr:.1f}",
                            (rc_x*2 + 8, rc_y*2 - 8),
                            cv2.FONT_HERSHEY_SIMPLEX,
                            0.4, (0, 255, 255), 1)
            if lc_x is not None and rc_x is not None:
                cv2.line(panel,
                         (lc_x*2, lc_y*2), (rc_x*2, rc_y*2),
                         (0, 255, 255), 1)

        if sides_detected == "both":
            diff       = abs(lc_raw - rc_raw)
            diff_color = (0, 255, 0) if diff < SYMMETRY_THRESH else (0, 0, 255)
            cv2.putText(panel1,
                        f"LC-RC diff: {diff:.1f}C",
                        (10, h*2 - 70),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.5, diff_color, 1)
        else:
            cv2.putText(panel1,
                        f"Single canthus only ({sides_detected.upper()})",
                        (10, h*2 - 70),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.5, (0, 165, 255), 1)

        if streak > 0:
            cv2.putText(panel1,
                        f"Fever streak: {streak}/{FEVER_CONFIRM_COUNT}",
                        (10, h*2 - 50),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.5, (0, 165, 255), 1)

        if holding:
            cv2.putText(panel1,
                        "HOLDING PREV READING",
                        (10, h*2 - 25),
                        cv2.FONT_HERSHEY_SIMPLEX,
                        0.55, (0, 200, 255), 2)
    else:
        cv2.putText(panel1, "NO CANTHUS DETECTED",
                    (20, 40),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    1.0, (128, 128, 128), 2)

    # Status bar
    bar_h = 90
    bar   = np.zeros((bar_h, w * 4, 3), dtype=np.uint8)

    canthus_raw  = max(lc_raw,  rc_raw)
    canthus_corr = max(lc_corr, rc_corr)
    display_label = f"{label} (holding)" if holding else label

    hum_str  = f"{humidity:.0f}%" if humidity else "N/A"
    src_icon = "BME280" if USE_BME280 else "fallback"
    amb_str  = (f"Ambient:{t_amb:.1f}C  RH:{hum_str}  "
                f"[{src_icon}]  "
                f"{datetime.now().strftime('%H:%M:%S')}")
    diff_part = f"diff:{abs(lc_raw-rc_raw):.1f}C" if sides_detected == "both" else f"sides:{sides_detected}"
    raw_str  = (f"RAW  LC:{lc_raw:.1f}  RC:{rc_raw:.1f}  "
                f"Canthus:{canthus_raw:.1f}C  "
                f"LCconf:{lc_conf:.2f} RCconf:{rc_conf:.2f}  "
                f"{diff_part}")
    cor_str  = (f"CORR LC:{lc_corr:.1f}  RC:{rc_corr:.1f}  "
                f"Canthus:{canthus_corr:.1f}C")

    cv2.putText(bar, amb_str,
                (10, 22), cv2.FONT_HERSHEY_SIMPLEX,
                0.55, (200, 200, 0), 1)
    cv2.putText(bar, raw_str,
                (10, 48), cv2.FONT_HERSHEY_SIMPLEX,
                0.5, (180, 180, 180), 1)
    cv2.putText(bar, cor_str,
                (10, 72), cv2.FONT_HERSHEY_SIMPLEX,
                0.5, color, 1)
    cv2.putText(bar, display_label,
                (w * 4 - 380, 62),
                cv2.FONT_HERSHEY_SIMPLEX,
                1.0, color, 2)

    top     = np.hstack([panel1, panel2])
    display = np.vstack([top, bar])
    return display, canthus_corr

