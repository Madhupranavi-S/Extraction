# CAMERA STATE
# =============================================================
linear_cal      = g.CameraLinearCal()
last_status     = [None]
last_frame      = [None]
last_valid      = [None]
no_detect_count = [0]
snapshot_count  = [0]
last_snap_time  = [time.time()]
fever_streak    = [0]

def on_frame(frame):
    last_frame[0] = frame
    if last_status[0] is not None:
        try:
            linear_cal.fit(frame.y16, last_status[0])
        except Exception:
            pass

# =============================================================
# MAIN
# =============================================================
def main():
    ap = argparse.ArgumentParser(
        description="Two-stage YOLO with SAHI on Stage 1")
    ap.add_argument("--detector", default=None,
                    help="Stage 1 face detector weights")
    ap.add_argument("--weights",  default=None,
                    help="Stage 2 canthus regressor weights")
    ap.add_argument("--port",     default="/dev/ttyACM0")
    args = ap.parse_args()

    # Resolve Stage 1 weights
    if args.detector:
        detector_path = Path(args.detector)
    else:
        det_candidates = [
            Path(__file__).parent / "thermal-canthus-detector" / "thermal_detector.pt",
            Path(__file__).parent / "thermal_detector.pt",
            Path.home() / "thermal-canthus-detector" / "thermal_detector.pt",
        ]
        detector_path = next(
            (p for p in det_candidates if p.exists()), det_candidates[0])

    # Resolve Stage 2 weights
    if args.weights:
        canthus_path = Path(args.weights)
    else:
        can_candidates = [
            Path(__file__).parent / "thermal-canthus-detector" / "thermal_canthus_yolo.pt",
            Path(__file__).parent / "thermal_canthus_yolo.pt",
            Path.home() / "thermal-canthus-detector" / "thermal_canthus_yolo.pt",
        ]
        canthus_path = next(
            (p for p in can_candidates if p.exists()), can_candidates[0])

    print(f"Stage 1 face detector:   {detector_path}")
    print(f"Stage 2 canthus model:   {canthus_path}")

    models = load_models(detector_path, canthus_path)

    # Keep a direct reference to Stage 1 model for SAHI
    # load_models returns an object — Stage 1 is models.detector
    stage1_model = models.detector
    print("Two-stage pipeline ready.")
    print(f"SAHI config: {SAHI_SLICE_H}x{SAHI_SLICE_W} patches, "
          f"{SAHI_OVERLAP*100:.0f}% overlap, "
          f"min face {MIN_FACE_PX}px")

    init_log()
    print(f"Logging to:   {LOG_FILE}")
    print(f"Snapshots to: {SNAP_DIR}")

    cam = g.Camera(g.DeviceInfo(serial_port=args.port))
    cam.configure_thermography(g.ThermographyConfig(emissivity=98))
    cam.start(on_frame)
    print("Warming up... 5 seconds")
    time.sleep(5)

    print("Calibrating...")
    for _ in range(20):
        try:
            s = cam.serial().query_temp_status(retries=2, wait_seconds=1.5)
            if s:
                last_status[0] = s
                if last_frame[0] is not None:
                    linear_cal.fit(last_frame[0].y16, s)
                print(f"Calibrated — min:{s.min_c:.1f}  max:{s.max_c:.1f}")
                break
        except Exception:
            pass
        time.sleep(1)

    if not linear_cal.ready():
        print("Calibration failed.")
        cam.stop()
        sys.exit(1)

    print("Live view started.")
    print("Q/Escape = quit  |  S = manual snapshot")
    cv2.namedWindow("Thermal Health Monitor", cv2.WINDOW_NORMAL)

    try:
        while True:
            # Refresh calibration
            try:
                s = cam.serial().query_temp_status(retries=1, wait_seconds=1.0)
                if s and last_frame[0] is not None:
                    last_status[0] = s
                    linear_cal.fit(last_frame[0].y16, s)
            except Exception:
                pass

            if last_frame[0] is None or not linear_cal.ready():
                time.sleep(0.05)
                continue

            # Wait for scene to stabilise
            wait_for_stable_scene(timeout=8.0)

            # Freeze one consistent frame
            frozen_frame, temps_avg, bgr = capture_stable_frame(
                n_avg=STABILITY_FRAMES)
            if frozen_frame is None:
                print("Frame capture failed — retrying")
                time.sleep(1)
                continue

            h, w = temps_avg.shape

            # Ambient
            t_amb, humidity = get_ambient()
            ambient_source  = "BME280" if USE_BME280 else "min_c fallback"

            # =================================================
            # STAGE 1: SAHI face detection on full frame
            # =================================================
            try:
                face_box, too_far, face_conf = _sahi_stage1(
                    stage1_model, bgr)
                face_found = face_box is not None
            except Exception as exc:
                print(f"Stage 1 error: {exc}")
                face_found = False
                too_far    = False
                face_box   = None
                face_conf  = 0.0

            # =================================================
            # STAGE 2: Canthus regressor on cropped face
            # Only runs if face found and large enough
            # =================================================
            left_pt = right_pt = None

            if face_found and not too_far:
                try:
                    fx1, fy1, fx2, fy2 = face_box

                    # Add small padding around face box
                    pad  = 10
                    fx1p = max(0, fx1 - pad)
                    fy1p = max(0, fy1 - pad)
                    fx2p = min(w, fx2 + pad)
                    fy2p = min(h, fy2 + pad)

                    face_crop      = bgr[fy1p:fy2p, fx1p:fx2p]
                    face_crop_prep = _clahe(face_crop)

                    # Run Stage 2 canthus regressor on the crop
                    result = yolo_detect(models,
                                         face_crop_prep,
                                         min_face_px=0)  # no size filter on crop

                    if result.left is not None:
                        lx, ly = result.left
                        left_pt = (lx + fx1p, ly + fy1p)
                    if result.right is not None:
                        rx, ry = result.right
                        right_pt = (rx + fx1p, ry + fy1p)

                except Exception as exc:
                    print(f"Stage 2 error: {exc}")

            face_detected = (left_pt is not None) or (right_pt is not None)
            holding       = False
            lc_corr       = 0.0
            rc_corr       = 0.0

            if face_detected:
                lc_x, lc_y = left_pt  if left_pt  is not None else (0, 0)
                rc_x, rc_y = right_pt if right_pt is not None else (0, 0)

                lc_raw = get_region_temp(temps_avg, lc_x, lc_y, radius=3) \
                         if left_pt  is not None else 0.0
                rc_raw = get_region_temp(temps_avg, rc_x, rc_y, radius=3) \
                         if right_pt is not None else 0.0

                canthus_raw = max(lc_raw, rc_raw)

                # Filter 1: Symmetry
                if not symmetry_check(lc_raw, rc_raw):
                    if last_valid[0] is not None:
                        r         = last_valid[0]
                        lc_raw    = r["lc_raw"];   rc_raw    = r["rc_raw"]
                        lc_corr   = r["lc_corr"];  rc_corr   = r["rc_corr"]
                        label     = r["label"];    color     = r["color"]
                        lc_xy     = r["lc_xy"];    rc_xy     = r["rc_xy"]
                        face_conf = r["face_conf"]
                        holding   = True
                    else:
                        face_detected = False

                # Filter 2: Spike guard
                elif not spike_guard(canthus_raw):
                    if last_valid[0] is not None:
                        r         = last_valid[0]
                        lc_raw    = r["lc_raw"];   rc_raw    = r["rc_raw"]
                        lc_corr   = r["lc_corr"];  rc_corr   = r["rc_corr"]
                        label     = r["label"];    color     = r["color"]
                        lc_xy     = r["lc_xy"];    rc_xy     = r["rc_xy"]
                        face_conf = r["face_conf"]
                        holding   = True
                    else:
                        face_detected = False

                else:
                    # Filter 3: Fever confirmation
                    lc_corr = compensate(lc_raw, t_amb)
                    rc_corr = compensate(rc_raw, t_amb)
                    canthus_corr = max(lc_corr, rc_corr)
                    label, color = confirmed_classify(canthus_corr)
                    lc_xy = (lc_x, lc_y)
                    rc_xy = (rc_x, rc_y)

                    last_valid[0] = {
                        "lc_raw":    lc_raw,    "rc_raw":    rc_raw,
                        "lc_corr":   lc_corr,   "rc_corr":   rc_corr,
                        "label":     label,     "color":     color,
                        "lc_xy":     lc_xy,     "rc_xy":     rc_xy,
                        "face_conf": face_conf, "face_box":  face_box,
                    }
                    no_detect_count[0] = 0

                if face_detected:
                    log_reading(lc_raw, rc_raw,
                                t_amb, humidity,
                                lc_corr, rc_corr,
                                face_conf,
                                label, ambient_source,
                                holding, fever_streak[0])

                    rh_str   = f"{humidity:.0f}%" if humidity else "N/A"
                    hold_str = " [holding]" if holding else ""
                    print(f"[{datetime.now().strftime('%H:%M:%S')}]  "
                          f"Amb:{t_amb:.1f}C RH:{rh_str}  "
                          f"face_conf:{face_conf:.2f}  "
                          f"diff:{abs(lc_raw-rc_raw):.1f}C  "
                          f"RAW LC:{lc_raw:.1f} RC:{rc_raw:.1f}  "
                          f"CORR LC:{lc_corr:.1f} RC:{rc_corr:.1f}  "
                          f"-> {label}{hold_str}")

            elif face_found and too_far:
                face_w = face_box[2] - face_box[0]
                print(f"Face found but too far "
                      f"(face {face_w}px < {MIN_FACE_PX}px min) "
                      f"— skipping canthus")
                no_detect_count[0] += 1
                if last_valid[0] is not None \
                        and no_detect_count[0] <= MAX_NO_DETECT:
                    r       = last_valid[0]
                    lc_raw  = r["lc_raw"];  rc_raw  = r["rc_raw"]
                    lc_corr = r["lc_corr"]; rc_corr = r["rc_corr"]
                    label   = r["label"];   color   = r["color"]
                    lc_xy   = r["lc_xy"];   rc_xy   = r["rc_xy"]
                    holding = True
                else:
                    last_valid[0] = None
                    lc_raw = rc_raw = lc_corr = rc_corr = 0.0
                    label, color = "TOO FAR", (0, 165, 255)
                    lc_xy = rc_xy = (0, 0)

            elif last_valid[0] is not None \
                    and no_detect_count[0] < MAX_NO_DETECT:
                no_detect_count[0] += 1
                r         = last_valid[0]
                lc_raw    = r["lc_raw"];   rc_raw    = r["rc_raw"]
                lc_corr   = r["lc_corr"];  rc_corr   = r["rc_corr"]
                label     = r["label"];    color     = r["color"]
                lc_xy     = r["lc_xy"];    rc_xy     = r["rc_xy"]
                face_conf = r["face_conf"]
                face_box  = r.get("face_box")
                face_detected = True
                holding   = True
                too_far   = False
                print(f"Holding last reading "
                      f"({no_detect_count[0]}/{MAX_NO_DETECT})")

            else:
                last_valid[0]      = None
                no_detect_count[0] = 0
                fever_streak[0]    = 0
                lc_raw = rc_raw = lc_corr = rc_corr = 0.0
                face_conf = 0.0
                label, color = "NO FACE", (128, 128, 128)
                lc_xy = rc_xy = (0, 0)
                face_box      = None
                face_detected = False
                too_far       = False
                holding       = False
                print("No face detected")

            lc_xy    = last_valid[0]["lc_xy"]    if last_valid[0] else (0, 0)
            rc_xy    = last_valid[0]["rc_xy"]    if last_valid[0] else (0, 0)
            face_box = last_valid[0].get("face_box") \
                       if last_valid[0] else face_box

            # Build display
            display, _ = build_debug_display(
                frozen_frame, temps_avg, bgr,
                face_detected, too_far, holding,
                lc_raw, rc_raw,
                lc_corr, rc_corr,
                face_conf,
                t_amb, humidity,
                label, color,
                lc_xy, rc_xy,
                face_box,
                ambient_source,
                fever_streak[0])

            cv2.imshow("Thermal Health Monitor", display)
            key = cv2.waitKey(30) & 0xFF

            if key in (ord('q'), ord('Q'), 27):
                print("Quitting...")
                break
            elif key in (ord('s'), ord('S')):
                snapshot_count[0] += 1
                fname = os.path.join(
                    SNAP_DIR,
                    f"snap_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
                    f"_{snapshot_count[0]:03d}.png")
                cv2.imwrite(fname, display)
                print(f"Manual snapshot: {fname}")

            now = time.time()
            if now - last_snap_time[0] >= AUTO_SNAPSHOT_INTERVAL:
                last_snap_time[0] = now
                snapshot_count[0] += 1
                fname = os.path.join(
                    SNAP_DIR,
                    f"snap_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
                    f"_auto_{snapshot_count[0]:03d}.png")
                cv2.imwrite(fname, display)
                print(f"Auto snapshot: {fname}")

    except KeyboardInterrupt:
        print("\nStopped.")
    finally:
        cam.stop()
        cv2.destroyAllWindows()
        print(f"Log:       {LOG_FILE}")
        print(f"Snapshots: {SNAP_DIR}")
        print("Stopped.")


if __name__ == "__main__":
    main()
