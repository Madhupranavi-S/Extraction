# =============================================================
# SAHI CONFIG — applied only to Stage 1 (face detection)
# =============================================================
SAHI_SLICE_H = 144   # patch height  (half of 288)
SAHI_SLICE_W = 192   # patch width   (half of 384)
SAHI_OVERLAP = 0.1   # 10% overlap — fewer patches, faster
MIN_FACE_PX  = 40    # minimum face box width to attempt canthus detection

def _clahe(img_bgr: np.ndarray) -> np.ndarray:
    """Contrast enhancement — same preprocessing as training."""
    gray  = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
    return cv2.cvtColor(clahe.apply(gray), cv2.COLOR_GRAY2RGB)

def _sahi_stage1(detector_model, bgr: np.ndarray):
    """
    Run Stage 1 face detector on overlapping patches of the full frame.
    Returns the best face bounding box (x1,y1,x2,y2) in full-frame coords,
    and whether the face is too small for canthus detection.
    """
    orig_h, orig_w = bgr.shape[:2]
    stride_y = int(SAHI_SLICE_H * (1 - SAHI_OVERLAP))
    stride_x = int(SAHI_SLICE_W * (1 - SAHI_OVERLAP))

    best_conf = -1.0
    best_box  = None  # (x1, y1, x2, y2) in full-frame coords

    y = 0
    while y < orig_h:
        y2 = min(y + SAHI_SLICE_H, orig_h)
        y1 = max(0, y2 - SAHI_SLICE_H)
        x = 0
        while x < orig_w:
            x2 = min(x + SAHI_SLICE_W, orig_w)
            x1 = max(0, x2 - SAHI_SLICE_W)

            patch      = bgr[y1:y2, x1:x2]
            patch_prep = _clahe(patch)

            # Run Stage 1 detector on this patch
            results = detector_model(patch_prep, verbose=False)[0]

            if results.boxes is not None and len(results.boxes) > 0:
                idx  = int(results.boxes.conf.cpu().numpy().argmax())
                conf = float(results.boxes.conf.cpu().numpy()[idx])

                if conf > best_conf:
                    # Get box in patch coords
                    box_xyxy = results.boxes.xyxy[idx].cpu().numpy()
                    px1 = int(box_xyxy[0]) + x1
                    py1 = int(box_xyxy[1]) + y1
                    px2 = int(box_xyxy[2]) + x1
                    py2 = int(box_xyxy[3]) + y1

                    # Clamp to full frame
                    px1 = max(0, min(px1, orig_w))
                    py1 = max(0, min(py1, orig_h))
                    px2 = max(0, min(px2, orig_w))
                    py2 = max(0, min(py2, orig_h))

                    best_box  = (px1, py1, px2, py2)
                    best_conf = conf

            x += stride_x
            if x2 == orig_w:
                break
        y += stride_y
        if y2 == orig_h:
            break

    if best_box is None:
        return None, False, best_conf

    face_w  = best_box[2] - best_box[0]
    too_far = face_w < MIN_FACE_PX

    return best_box, too_far, best_conf

