# =============================================================
# SINGLE-STAGE MODEL CONFIG
# =============================================================
# best.pt / detect.pt was TRAINED on SAHI-sliced crops.
# At inference we also slice with SAHI (matching training geometry)
# and merge detections back into full-frame coordinates.
#   Class 0 -> left_inner_canthus
#   Class 1 -> right_inner_canthus
CLASS_LEFT  = 0
CLASS_RIGHT = 1

# Base confidence threshold — used as a fallback / CLI override.
# Real per-tier floors live in SAHI_CONFIGS below (Phase 1 change).
CONF_THRESH = 0.20
IMG_SIZE    = 320   # imgsz fed to the model per-slice

# =============================================================
# MULTI-SCALE SAHI CONFIG
# Three scale tiers so the pipeline handles arm-length, mid-range,
# and far subjects without a single fixed tile size cutting off
# the canthus or losing spatial context.
#
#  tier 0 — CLOSE  (arm's length, ~0.5-1.5 m): large tiles so the
#            model has plenty of surrounding eye context.
#  tier 1 — MID    (~1.5-3 m): original safe geometry.
#  tier 2 — FAR    (>3 m): small tiles + aggressive upscale.
#
# --- PHASE 1 CHANGE ---
# Each tuple now carries its OWN confidence floor as a 5th value:
#   (slice_w, slice_h, overlap, upscale, conf_floor)
#
# Why: tier 2 uses tiny 64x48 tiles upscaled 3.5x. Small tiles see
# less context per inference and structurally produce more
# low-confidence noise than tier 0's large tiles. One global
# CONF_THRESH for all three tiers means it's always wrong for at
# least one tier — too loose for far, or too strict for close.
#
# Starting values below are reasonable defaults, not measured —
# tune live by watching which tier's hits look like noise in your
# logs once VERBOSE_SAHI is turned on for a debugging session.
# =============================================================
SAHI_CONFIGS = [
    (128, 96,  0.35, 1.5, 0.22),   # tier 0 - close  (slightly stricter: large context, less noise expected)
    (96,  72,  0.40, 2.0, 0.20),   # tier 1 - mid    (original baseline)
    (64,  48,  0.50, 3.5, 0.28),   # tier 2 - far    (stricter: tiny tiles + heavy upscale = more noise)
]

SAHI_MERGE_IOU = 0.30   # IoU threshold for cross-slice NMS

# --- PHASE 1 CHANGE ---
# Hard noise floor applied to EVERY detection before it is even
# added to the NMS candidate pool, regardless of tier. This is
# the actual fix for "ghost canthus" hits like conf=0.054 surviving
# to become the final answer (previously: no competing detection
# for that class -> the lone ghost wins by default since NMS only
# suppresses duplicates, it doesn't reject low absolute confidence).
HARD_CONF_FLOOR = 0.18

# --- PHASE 1 CHANGE ---
# After NMS, additionally discard any kept detection that sits far
# below the best detection of the SAME class. A real canthus and a
# ghost rarely overlap enough for IoU-NMS to merge them (that's why
# the ghost survives NMS in the first place) — so we also gate on
# relative confidence gap as a second, independent filter.
GHOST_RELATIVE_GAP = 0.35


# =============================================================
# PREPROCESSING
# =============================================================
# Keep this identical to training distribution.
# CLAHE is OFF by default because the model was trained without it.
# Enable --clahe at the command line if you retrain with CLAHE aug.
_CLAHE_ENABLED = False

def _preprocess(img_bgr: np.ndarray) -> np.ndarray:
    """
    Optionally apply CLAHE to enhance canthus contrast at long range.
    Only safe to enable when the model was also trained with CLAHE
    augmentation — otherwise it shifts the input distribution and
    hurts detection.
    """
    if not _CLAHE_ENABLED:
        return img_bgr
    lab = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(4, 4))
    l = clahe.apply(l)
    enhanced = cv2.merge([l, a, b])
    return cv2.cvtColor(enhanced, cv2.COLOR_LAB2BGR)


def _debug_preprocess(img_bgr: np.ndarray):
    """
    One-shot diagnostic — prints channel statistics so you can
    confirm BGR channel order and uint8 dtype match training.
    Call once at startup then remove.
    """
    assert img_bgr.dtype == np.uint8, \
        f"[PREPROCESS] Expected uint8, got {img_bgr.dtype}"
