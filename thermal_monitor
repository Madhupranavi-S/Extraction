                f"LCconf:{lc_conf:.2f} RCconf:{rc_conf:.2f}  "
                f"{diff_part}")
    cor_str  = (f"CORR LC:{lc_corr:.1f}  RC:{rc_corr:.1f}  "
                f"Canthus:{canthus_corr:.1f}C")

    cv2.putText(bar, amb_str,  (10, 22), cv2.FONT_HERSHEY_SIMPLEX,
                0.55, (200, 200, 0), 1)
    cv2.putText(bar, raw_str,  (10, 48), cv2.FONT_HERSHEY_SIMPLEX,
                0.5,  (180, 180, 180), 1)
    cv2.putText(bar, cor_str,  (10, 72), cv2.FONT_HERSHEY_SIMPLEX,
                0.5,  color, 1)
    cv2.putText(bar, display_label, (w * 4 - 380, 62),
                cv2.FONT_HERSHEY_SIMPLEX, 1.0, color, 2)

    top     = np.hstack([panel1, panel2])
    display = np.vstack([top, bar])
    return display, canthus_corr


# =============================================================
# CAMERA STATE
# =============================================================
linear_cal      = g.CameraLinearCal()
last_status     = [None]
last_frame      = [None]
last_valid      = [None]
no_detect_count = [0]
snapshot_count  = [0]
last_snap_time  = [time.time()]
fever_streak    = [0]


def on_frame(frame):
    last_frame[0] = frame
    if last_status[0] is not None:
        try:
            linear_cal.fit(frame.y16, last_status[0])
        except Exception:
            pass


# =============================================================
# MAIN
# =============================================================
def main():
    global CONF_THRESH, VERBOSE_SAHI, SANITY_CHECK, _CLAHE_ENABLED

    ap = argparse.ArgumentParser(
        description="Multi-scale SAHI canthus detector (detect.pt / best.pt)")
    ap.add_argument("--weights",  default=None,
                    help="Path to canthus model weights")
    ap.add_argument("--port",     default="/dev/ttyACM0")
    ap.add_argument("--imgsz",    type=int,   default=IMG_SIZE,
                    help="Inference image size per slice (default 320)")
    ap.add_argument("--conf",     type=float, default=CONF_THRESH,
                    help="Base confidence threshold (default 0.20)")
    ap.add_argument("--no-verbose", action="store_true",
                    help="Suppress per-slice SAHI hit output")
    ap.add_argument("--no-sanity",  action="store_true",
                    help="Disable whole-frame sanity check each cycle")
    ap.add_argument("--clahe",      action="store_true",
                    help="Enable CLAHE preprocessing (only if model was "
                         "trained with CLAHE augmentation)")
    args = ap.parse_args()

    CONF_THRESH      = args.conf
    VERBOSE_SAHI     = not args.no_verbose
    SANITY_CHECK     = not args.no_sanity
    _CLAHE_ENABLED   = args.clahe

    # Resolve weights path
    if args.weights:
        weights_path = Path(args.weights)
    else:
        candidates = [
            Path(__file__).parent / "thermal-canthus-detector" / "detect.pt",
            Path(__file__).parent / "detect.pt",
            Path.home() / "thermal-canthus-detector" / "detect.pt",
            Path(__file__).parent / "thermal-canthus-detector" / "best.pt",
            Path(__file__).parent / "best.pt",
            Path.home() / "thermal-canthus-detector" / "best.pt",
        ]
        weights_path = next(
            (p for p in candidates if p.exists()), candidates[0])

    print(f"Canthus model : {weights_path}")
    model = YOLO(str(weights_path))

    print("Multi-scale SAHI pipeline ready.")
    print(f"  conf={CONF_THRESH}  imgsz={args.imgsz}  "
          f"clahe={_CLAHE_ENABLED}  "
          f"verbose_sahi={VERBOSE_SAHI}  sanity={SANITY_CHECK}")
    print("  Scale tiers (slice_w x slice_h  overlap  upscale):")
    for i, (sw, sh, ov, up) in enumerate(SAHI_CONFIGS):
        print(f"    tier {i}: {sw}x{sh}  overlap={ov}  upscale={up}x  "
              f"-> model sees {int(sw*up)}x{int(sh*up)}")

    init_log()
    print(f"Logging to:   {LOG_FILE}")
    print(f"Snapshots to: {SNAP_DIR}")

    cam = g.Camera(g.DeviceInfo(serial_port=args.port))
    cam.configure_thermography(g.ThermographyConfig(emissivity=98))
    cam.start(on_frame)
    print("Warming up... 5 seconds")
    time.sleep(5)

    print("Calibrating...")
    for _ in range(20):
        try:
            s = cam.serial().query_temp_status(retries=2, wait_seconds=1.5)
            if s:
                last_status[0] = s
                if last_frame[0] is not None:
                    linear_cal.fit(last_frame[0].y16, s)
                print(f"Calibrated — min:{s.min_c:.1f}  max:{s.max_c:.1f}")
                break
        except Exception:
            pass
        time.sleep(1)

    if not linear_cal.ready():
        print("Calibration failed.")
        cam.stop()
        sys.exit(1)

    print("Live view started.")
    print("Q / Escape = quit  |  S = manual snapshot")
    cv2.namedWindow("Thermal Health Monitor", cv2.WINDOW_NORMAL)

    try:
        while True:
            # Refresh calibration
            try:
                s = cam.serial().query_temp_status(retries=1, wait_seconds=1.0)
                if s and last_frame[0] is not None:
                    last_status[0] = s
                    linear_cal.fit(last_frame[0].y16, s)
            except Exception:
                pass

            if last_frame[0] is None or not linear_cal.ready():
                time.sleep(0.05)
                continue

            # Wait for scene to stabilise
            wait_for_stable_scene(timeout=8.0)

            # Freeze one consistent frame
            frozen_frame, temps_avg, bgr = capture_stable_frame(
                n_avg=STABILITY_FRAMES)
            if frozen_frame is None:
                print("Frame capture failed — retrying")
                time.sleep(1)
                continue

            h, w = temps_avg.shape

            # One-shot dtype / channel check on the very first frame
            if not _preprocess_checked[0]:
                _debug_preprocess(bgr)
                _preprocess_checked[0] = True

            # Ambient
            t_amb, humidity = get_ambient()
            ambient_source  = "BME280" if USE_BME280 else "min_c fallback"

            # =================================================
            # MULTI-SCALE SAHI canthus detection
            # =================================================
            try:
                left_pt, right_pt, lc_conf, rc_conf = _single_stage_detect(
                    model, bgr,
                    verbose=VERBOSE_SAHI,
                    sanity=SANITY_CHECK)
            except Exception as exc:
                print(f"Detection error: {exc}")
                left_pt = right_pt = None
                lc_conf = rc_conf = 0.0

            face_detected  = (left_pt is not None) or (right_pt is not None)
            holding        = False
            lc_corr        = 0.0
            rc_corr        = 0.0
            sides_detected = "none"

            if face_detected:
                if left_pt is not None and right_pt is not None:
                    sides_detected = "both"
                elif left_pt is not None:
                    sides_detected = "left"
                else:
                    sides_detected = "right"

                lc_x, lc_y = left_pt  if left_pt  is not None else (None, None)
                rc_x, rc_y = right_pt if right_pt is not None else (None, None)

                lc_raw = (get_region_temp(temps_avg, int(lc_x), int(lc_y), radius=3)
                          if left_pt  is not None else 0.0)
                rc_raw = (get_region_temp(temps_avg, int(rc_x), int(rc_y), radius=3)
                          if right_pt is not None else 0.0)

                canthus_raw = max(lc_raw, rc_raw)

                # Symmetry check only when both sides detected
                passed_symmetry = True
                if sides_detected == "both":
                    passed_symmetry = symmetry_check(lc_raw, rc_raw)

                if not passed_symmetry:
                    if last_valid[0] is not None:
                        r = last_valid[0]
                        lc_raw  = r["lc_raw"];   rc_raw  = r["rc_raw"]
                        lc_corr = r["lc_corr"];  rc_corr = r["rc_corr"]
                        label   = r["label"];    color   = r["color"]
                        lc_xy   = r["lc_xy"];    rc_xy   = r["rc_xy"]
                        lc_conf = r["lc_conf"];  rc_conf = r["rc_conf"]
                        sides_detected = r["sides_detected"]
                        holding = True
                    else:
                        face_detected = False

                elif not spike_guard(canthus_raw):
                    if last_valid[0] is not None:
                        r = last_valid[0]
                        lc_raw  = r["lc_raw"];   rc_raw  = r["rc_raw"]
                        lc_corr = r["lc_corr"];  rc_corr = r["rc_corr"]
                        label   = r["label"];    color   = r["color"]
                        lc_xy   = r["lc_xy"];    rc_xy   = r["rc_xy"]
                        lc_conf = r["lc_conf"];  rc_conf = r["rc_conf"]
                        sides_detected = r["sides_detected"]
                        holding = True
                    else:
                        face_detected = False

                else:
                    lc_corr = (compensate(lc_raw, t_amb)
                               if left_pt  is not None else 0.0)
                    rc_corr = (compensate(rc_raw, t_amb)
                               if right_pt is not None else 0.0)
                    canthus_corr = max(lc_corr, rc_corr)
                    label, color = confirmed_classify(canthus_corr)
                    lc_xy = (lc_x, lc_y) if left_pt  is not None else (None, None)
                    rc_xy = (rc_x, rc_y) if right_pt is not None else (None, None)

                    last_valid[0] = {
                        "lc_raw":  lc_raw,  "rc_raw":  rc_raw,
                        "lc_corr": lc_corr, "rc_corr": rc_corr,
                        "label":   label,   "color":   color,
                        "lc_xy":   lc_xy,   "rc_xy":   rc_xy,
                        "lc_conf": lc_conf, "rc_conf": rc_conf,
                        "sides_detected": sides_detected,
                    }
                    no_detect_count[0] = 0

                if face_detected:
                    log_reading(lc_raw, rc_raw,
                                t_amb, humidity,
                                lc_corr, rc_corr,
                                lc_conf, rc_conf, sides_detected,
                                label, ambient_source,
                                holding, fever_streak[0])

                    rh_str   = f"{humidity:.0f}%" if humidity else "N/A"
                    hold_str = " [holding]" if holding else ""
                    diff_str = (f"diff:{abs(lc_raw-rc_raw):.1f}C  "
                                if sides_detected == "both"
                                else f"sides:{sides_detected}  ")
                    print(f"[{datetime.now().strftime('%H:%M:%S')}]  "
                          f"Amb:{t_amb:.1f}C RH:{rh_str}  "
                          f"LCconf:{lc_conf:.2f} RCconf:{rc_conf:.2f}  "
                          f"{diff_str}"
                          f"RAW LC:{lc_raw:.1f} RC:{rc_raw:.1f}  "
                          f"CORR LC:{lc_corr:.1f} RC:{rc_corr:.1f}  "
                          f"-> {label}{hold_str}")

            elif (last_valid[0] is not None
                  and no_detect_count[0] < MAX_NO_DETECT):
                no_detect_count[0] += 1
                r = last_valid[0]
                lc_raw  = r["lc_raw"];   rc_raw  = r["rc_raw"]
                lc_corr = r["lc_corr"];  rc_corr = r["rc_corr"]
                label   = r["label"];    color   = r["color"]
                lc_xy   = r["lc_xy"];    rc_xy   = r["rc_xy"]
                lc_conf = r["lc_conf"];  rc_conf = r["rc_conf"]
                sides_detected = r["sides_detected"]
                face_detected  = True
                holding        = True
                print(f"Holding last reading "
                      f"({no_detect_count[0]}/{MAX_NO_DETECT})")

            else:
                last_valid[0]      = None
                no_detect_count[0] = 0
                fever_streak[0]    = 0
                lc_raw = rc_raw = lc_corr = rc_corr = 0.0
                lc_conf = rc_conf = 0.0
                sides_detected = "none"
                label, color = "NO FACE", (128, 128, 128)
                lc_xy = rc_xy = (None, None)
                face_detected = False
                holding       = False
                print("No canthus detected")

            lc_xy = last_valid[0]["lc_xy"] if last_valid[0] else (None, None)
            rc_xy = last_valid[0]["rc_xy"] if last_valid[0] else (None, None)

            # Build display
            display, _ = build_debug_display(
                frozen_frame, temps_avg, bgr,
                face_detected, sides_detected, holding,
                lc_raw, rc_raw,
                lc_corr, rc_corr,
                lc_conf, rc_conf,
                t_amb, humidity,
                label, color,
                lc_xy, rc_xy,
                ambient_source,
                fever_streak[0])

            cv2.imshow("Thermal Health Monitor", display)
            key = cv2.waitKey(30) & 0xFF

            if key in (ord('q'), ord('Q'), 27):
                print("Quitting...")
                break
            elif key in (ord('s'), ord('S')):
                snapshot_count[0] += 1
                fname = os.path.join(
                    SNAP_DIR,
                    f"snap_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
                    f"_{snapshot_count[0]:03d}.png")
                cv2.imwrite(fname, display)
                print(f"Manual snapshot: {fname}")

            now = time.time()
            if now - last_snap_time[0] >= AUTO_SNAPSHOT_INTERVAL:
                last_snap_time[0] = now
                snapshot_count[0] += 1
                fname = os.path.join(
                    SNAP_DIR,
                    f"snap_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
                    f"_auto_{snapshot_count[0]:03d}.png")
                cv2.imwrite(fname, display)
                print(f"Auto snapshot: {fname}")

    except KeyboardInterrupt:
        print("\nStopped.")
    finally:
        cam.stop()
        cv2.destroyAllWindows()
        print(f"Log:       {LOG_FILE}")
        print(f"Snapshots: {SNAP_DIR}")
        print("Stopped.")


if __name__ == "__main__":
    main()
