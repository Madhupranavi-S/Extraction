# =============================================================
# SINGLE-STAGE MODEL CONFIG
# =============================================================
# best.pt / detect.pt was TRAINED on SAHI-sliced crops.
# At inference we also slice with SAHI (matching training geometry)
# and merge detections back into full-frame coordinates.
#   Class 0 -> left_inner_canthus
#   Class 1 -> right_inner_canthus
CLASS_LEFT  = 0
CLASS_RIGHT = 1

# Base confidence threshold — lowered slightly so far/small targets
# are not immediately discarded. Adaptive per-detection logic below
# will tighten this for close subjects automatically.
CONF_THRESH = 0.20
IMG_SIZE    = 320   # imgsz fed to the model per-slice

# =============================================================
# MULTI-SCALE SAHI CONFIG
# Three scale tiers so the pipeline handles arm-length, mid-range,
# and far subjects without a single fixed tile size cutting off
# the canthus or losing spatial context.
#
#  tier 0 — CLOSE  (arm's length, ~0.5–1.5 m): large tiles so the
#            model has plenty of surrounding eye context.
#  tier 1 — MID    (~1.5–3 m): original safe geometry.
#  tier 2 — FAR    (>3 m): small tiles + aggressive upscale.
#
# Each tuple: (slice_w, slice_h, overlap, upscale)
# =============================================================
SAHI_CONFIGS = [
    (128, 96,  0.35, 1.5),   # tier 0 — close
    (96,  72,  0.40, 2.0),   # tier 1 — mid   (original)
    (64,  48,  0.50, 3.5),   # tier 2 — far
]

SAHI_MERGE_IOU = 0.30   # IoU threshold for cross-slice NMS


# =============================================================
# PREPROCESSING
# =============================================================
# Keep this identical to training distribution.
# CLAHE is OFF by default because the model was trained without it.
# Enable --clahe at the command line if you retrain with CLAHE aug.
_CLAHE_ENABLED = False

def _preprocess(img_bgr: np.ndarray) -> np.ndarray:
    """
    Optionally apply CLAHE to enhance canthus contrast at long range.
    Only safe to enable when the model was also trained with CLAHE
    augmentation — otherwise it shifts the input distribution and
    hurts detection.
    """
    if not _CLAHE_ENABLED:
        return img_bgr
    lab = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(4, 4))
    l = clahe.apply(l)
    enhanced = cv2.merge([l, a, b])
    return cv2.cvtColor(enhanced, cv2.COLOR_LAB2BGR)


def _debug_preprocess(img_bgr: np.ndarray):
    """
    One-shot diagnostic — prints channel statistics so you can
    confirm BGR channel order and uint8 dtype match training.
    Call once at startup then remove.
    """
    assert img_bgr.dtype == np.uint8, \
        f"[PREPROCESS] Expected uint8, got {img_bgr.dtype}"
    assert len(img_bgr.shape) == 3 and img_bgr.shape[2] == 3, \
        f"[PREPROCESS] Expected HxWx3, got {img_bgr.shape}"
    print(f"[PREPROCESS] dtype={img_bgr.dtype}  shape={img_bgr.shape}  "
          f"channel means: B={img_bgr[:,:,0].mean():.1f} "
          f"G={img_bgr[:,:,1].mean():.1f} "
          f"R={img_bgr[:,:,2].mean():.1f}")


# =============================================================
# SAHI UTILITIES
# =============================================================
def _make_slices(width: int, height: int,
                 slice_w: int, slice_h: int, overlap: float):
    """
    Generate (x1, y1, x2, y2) slice boxes for ONE scale tier.
    The last slice in each axis is pulled back from the far edge
    rather than running off frame, matching training crop generation.
    """
    stride_x = max(1, int(slice_w * (1 - overlap)))
    stride_y = max(1, int(slice_h * (1 - overlap)))

    xs = list(range(0, max(width  - slice_w, 0) + 1, stride_x))
    ys = list(range(0, max(height - slice_h, 0) + 1, stride_y))

    if not xs or xs[-1] != max(width  - slice_w, 0):
        xs.append(max(width  - slice_w, 0))
    if not ys or ys[-1] != max(height - slice_h, 0):
        ys.append(max(height - slice_h, 0))

    slices = []
    for y1 in ys:
        y2 = min(y1 + slice_h, height)
        y1 = max(0, y2 - slice_h)
        for x1 in xs:
            x2 = min(x1 + slice_w, width)
            x1 = max(0, x2 - slice_w)
            slices.append((x1, y1, x2, y2))
    return slices


def _iou(box_a, box_b) -> float:
    ax1, ay1, ax2, ay2 = box_a
    bx1, by1, bx2, by2 = box_b
    ix1 = max(ax1, bx1);  iy1 = max(ay1, by1)
    ix2 = min(ax2, bx2);  iy2 = min(ay2, by2)
    iw  = max(0.0, ix2 - ix1)
    ih  = max(0.0, iy2 - iy1)
    inter = iw * ih
    if inter <= 0:
        return 0.0
    area_a = max(0.0, ax2 - ax1) * max(0.0, ay2 - ay1)
    area_b = max(0.0, bx2 - bx1) * max(0.0, by2 - by1)
    union  = area_a + area_b - inter
    return inter / union if union > 0 else 0.0


def _nms_merge(dets):
    """
    Greedy NMS over [(box_xyxy, conf)] for a single class.
    Collapses duplicates from overlapping tiles down to the
    single highest-confidence box.
    """
    if not dets:
        return []
    dets = sorted(dets, key=lambda d: d[1], reverse=True)
    kept = []
    used = [False] * len(dets)
    for i, (box_i, conf_i) in enumerate(dets):
        if used[i]:
            continue
        kept.append((box_i, conf_i))
        for j in range(i + 1, len(dets)):
            if not used[j] and _iou(box_i, dets[j][0]) > SAHI_MERGE_IOU:
                used[j] = True
    return kept


# =============================================================
# WHOLE-FRAME SANITY CHECK  (diagnostic only)
# =============================================================
def _sanity_check_whole_frame(model, bgr: np.ndarray):
    """
    Run the model on the full frame at conf=0.05.
    If this finds nothing, the problem is weights/preprocessing,
    not slice geometry. Disable by setting SANITY_CHECK=False.
    """
    results = model(bgr, imgsz=IMG_SIZE, conf=0.05, verbose=False)[0]
    if results.boxes is not None and len(results.boxes) > 0:
        confs = results.boxes.conf.cpu().numpy().round(3)
        clss  = results.boxes.cls.cpu().numpy().astype(int).tolist()
        print(f"[SANITY] Whole-frame hits: conf={confs}  cls={clss}")
    else:
        print("[SANITY] Whole-frame: NOTHING at conf=0.05 "
              "— verify weights path and BGR channel order")


# =============================================================
# MULTI-SCALE SAHI DETECTION
# =============================================================
def _single_stage_detect(model, bgr: np.ndarray,
                          verbose: bool = False,
                          sanity: bool = False):
    """
    Multi-scale SAHI inference for the single-stage canthus model.

    Runs three scale tiers (close / mid / far) independently.
    All detections from all tiers are mapped back to full-frame
    pixel coordinates then merged per-class with NMS. The single
    highest-confidence box per class is returned.

    Parameters
    ----------
    model   : loaded YOLO model
    bgr     : full frame in BGR uint8
    verbose : print per-slice hit details
    sanity  : run whole-frame sanity check before slicing

    Returns
    -------
    (left_pt, right_pt, left_conf, right_conf)
        Points are (x, y) float in full-frame pixels, or None if
        that class was not found in any tile.
    """
    prepped = _preprocess(bgr)
    h, w    = prepped.shape[:2]

    if sanity:
        _sanity_check_whole_frame(model, prepped)

    left_dets  = []   # list of (box_xyxy_fullframe, conf)
    right_dets = []
    total_slices = 0
    total_hits   = 0

    for tier_idx, (sw, sh, overlap, upscale) in enumerate(SAHI_CONFIGS):
        slices = _make_slices(w, h, sw, sh, overlap)
        total_slices += len(slices)

        if verbose:
            print(f"[SAHI] tier={tier_idx}  "
                  f"tile={sw}x{sh}  overlap={overlap}  upscale={upscale}x  "
                  f"-> model input {int(sw*upscale)}x{int(sh*upscale)}  "
                  f"slices={len(slices)}")

        for (x1, y1, x2, y2) in slices:
            patch = prepped[y1:y2, x1:x2]
            if patch.size == 0:
                continue

            # Upscale gives the model more effective resolution for
            # tiny / far-away canthi without changing what the patch shows.
            if upscale != 1.0:
                patch_in = cv2.resize(
                    patch, None, fx=upscale, fy=upscale,
                    interpolation=cv2.INTER_LANCZOS4)
            else:
                patch_in = patch

            results = model(
                patch_in, imgsz=IMG_SIZE,
                conf=CONF_THRESH, verbose=False)[0]

            if results.boxes is None or len(results.boxes) == 0:
                continue

            boxes = results.boxes.xyxy.cpu().numpy()
            clss  = results.boxes.cls.cpu().numpy().astype(int)
            confs = results.boxes.conf.cpu().numpy()
            total_hits += len(boxes)

            if verbose:
                print(f"  HIT tier={tier_idx} "
                      f"slice ({x1},{y1})-({x2},{y2})  "
                      f"conf={confs.round(3)}  cls={clss.tolist()}")

            for box, cls_id, conf in zip(boxes, clss, confs):
                # Map from upscaled-patch coords -> full-frame coords
                full_box = (
                    float(box[0] / upscale + x1),
                    float(box[1] / upscale + y1),
                    float(box[2] / upscale + x1),
                    float(box[3] / upscale + y1),
                )
                if cls_id == CLASS_LEFT:
                    left_dets.append((full_box, float(conf)))
                elif cls_id == CLASS_RIGHT:
                    right_dets.append((full_box, float(conf)))

    if verbose:
        print(f"[SAHI] Total slices across all tiers: {total_slices}  "
              f"raw hits: {total_hits}  "
              f"left raw: {len(left_dets)}  right raw: {len(right_dets)}")

    # Per-class NMS to collapse cross-tile / cross-tier duplicates
    left_dets  = _nms_merge(left_dets)
    right_dets = _nms_merge(right_dets)

    left_pt    = None
    right_pt   = None
    left_conf  = 0.0
    right_conf = 0.0

    if left_dets:
        (lx1, ly1, lx2, ly2), left_conf = max(left_dets, key=lambda d: d[1])
        left_pt = (float((lx1 + lx2) / 2.0),
                   float((ly1 + ly2) / 2.0))

    if right_dets:
        (rx1, ry1, rx2, ry2), right_conf = max(right_dets, key=lambda d: d[1])
        right_pt = (float((rx1 + rx2) / 2.0),
                    float((ry1 + ry2) / 2.0))

    return left_pt, right_pt, left_conf, right_conf


