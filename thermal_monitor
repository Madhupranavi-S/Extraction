          f"G={img_bgr[:,:,1].mean():.1f} "
          f"R={img_bgr[:,:,2].mean():.1f}")


# =============================================================
# SAHI UTILITIES
# =============================================================
def _make_slices(width: int, height: int,
                 slice_w: int, slice_h: int, overlap: float):
    """
    Generate (x1, y1, x2, y2) slice boxes for ONE scale tier.
    The last slice in each axis is pulled back from the far edge
    rather than running off frame, matching training crop generation.
    """
    stride_x = max(1, int(slice_w * (1 - overlap)))
    stride_y = max(1, int(slice_h * (1 - overlap)))

    xs = list(range(0, max(width  - slice_w, 0) + 1, stride_x))
    ys = list(range(0, max(height - slice_h, 0) + 1, stride_y))

    if not xs or xs[-1] != max(width  - slice_w, 0):
        xs.append(max(width  - slice_w, 0))
    if not ys or ys[-1] != max(height - slice_h, 0):
        ys.append(max(height - slice_h, 0))

    slices = []
    for y1 in ys:
        y2 = min(y1 + slice_h, height)
        y1 = max(0, y2 - slice_h)
        for x1 in xs:
            x2 = min(x1 + slice_w, width)
            x1 = max(0, x2 - slice_w)
            slices.append((x1, y1, x2, y2))
    return slices


def _iou(box_a, box_b) -> float:
    ax1, ay1, ax2, ay2 = box_a
    bx1, by1, bx2, by2 = box_b
    ix1 = max(ax1, bx1);  iy1 = max(ay1, by1)
    ix2 = min(ax2, bx2);  iy2 = min(ay2, by2)
    iw  = max(0.0, ix2 - ix1)
    ih  = max(0.0, iy2 - iy1)
    inter = iw * ih
    if inter <= 0:
        return 0.0
    area_a = max(0.0, ax2 - ax1) * max(0.0, ay2 - ay1)
    area_b = max(0.0, bx2 - bx1) * max(0.0, by2 - by1)
    union  = area_a + area_b - inter
    return inter / union if union > 0 else 0.0


def _nms_merge(dets):
    """
    Greedy NMS over [(box_xyxy, conf)] for a single class.
    Collapses duplicates from overlapping tiles down to the
    single highest-confidence box.

    --- PHASE 1 CHANGE ---
    After standard IoU-NMS, also drop any surviving detection whose
    confidence is more than GHOST_RELATIVE_GAP below the top
    detection. A ghost (e.g. nose bridge misread as a canthus while
    turning) is usually spatially SEPARATE from the real detection,
    so IoU-NMS alone never touches it — this second pass catches it.
    """
    if not dets:
        return []
    dets = sorted(dets, key=lambda d: d[1], reverse=True)
    kept = []
    used = [False] * len(dets)
    for i, (box_i, conf_i) in enumerate(dets):
        if used[i]:
            continue
        kept.append((box_i, conf_i))
        for j in range(i + 1, len(dets)):
            if not used[j] and _iou(box_i, dets[j][0]) > SAHI_MERGE_IOU:
                used[j] = True

    if not kept:
        return kept
    top_conf = kept[0][1]
    before_n = len(kept)
    kept = [(box, c) for box, c in kept if c >= top_conf - GHOST_RELATIVE_GAP]
    dropped_n = before_n - len(kept)
    if dropped_n > 0:
        print(f"  [ghost filter] dropped {dropped_n} detection(s) "
              f">{GHOST_RELATIVE_GAP:.2f} below top conf {top_conf:.3f}")
    return kept


# =============================================================
# GEOMETRIC PLAUSIBILITY CHECK
# =============================================================
def _plausibility_check(left_pt, right_pt, frame_w, frame_h) -> bool:
    """
    Reject detection pairs that are geometrically implausible for
    two inner canthi on a human face. This is what actually catches
    the "face turning -> ghost paired with real detection" failure
    mode, independent of confidence — a ghost from the nose bridge
    can have high-ish confidence but will usually be spatially wrong.
    """
    if left_pt is None or right_pt is None:
        return True  # single canthus is always plausible

    lx, ly = left_pt
    rx, ry = right_pt

    dx = abs(rx - lx)
    dy = abs(ry - ly)

    # Canthi must be horizontally separated by at least 5% of frame width
    if dx < frame_w * 0.05:
        print(f"  [plausibility] rejected — canthi too close horizontally "
              f"dx={dx:.1f}px (min {frame_w*0.05:.1f}px)")
        return False

    # Vertical offset should be small — canthi are at roughly same height.
    # Allow up to 15% of frame height for head tilt.
    if dy > frame_h * 0.15:
        print(f"  [plausibility] rejected — canthi vertical offset too large "
              f"dy={dy:.1f}px (max {frame_h*0.15:.1f}px)")
        return False

    # Left canthus x should be LEFT of right canthus x (camera's
    # perspective, mirrored). Allow a small tolerance for NMS centre error.
    if lx > rx + frame_w * 0.05:
        print(f"  [plausibility] rejected — canthi swapped: "
              f"LC.x={lx:.1f} > RC.x={rx:.1f}")
        return False

    return True


# =============================================================
# WHOLE-FRAME SANITY CHECK  (diagnostic only — OFF by default)
# =============================================================
def _sanity_check_whole_frame(model, bgr: np.ndarray):
    """
    Run the model on the full frame at conf=0.05.
    If this finds nothing, the problem is weights/preprocessing,
    not slice geometry.

    --- PHASE 1 CHANGE ---
    This used to run unconditionally every cycle, adding a full
    extra inference pass per frame purely for logging. It is now
    gated behind SANITY_CHECK, which defaults to False (see CLI
    --debug-sanity to re-enable for a debugging session).
    """
    results = model(bgr, imgsz=IMG_SIZE, conf=0.05, verbose=False)[0]
    if results.boxes is not None and len(results.boxes) > 0:
        confs = results.boxes.conf.cpu().numpy().round(3)
        clss  = results.boxes.cls.cpu().numpy().astype(int).tolist()
        print(f"[SANITY] Whole-frame hits: conf={confs}  cls={clss}")
    else:
        print("[SANITY] Whole-frame: NOTHING at conf=0.05 "
              "— verify weights path and BGR channel order")


# =============================================================
# MULTI-SCALE SAHI DETECTION
# =============================================================
def _single_stage_detect(model, bgr: np.ndarray,
                          verbose: bool = False,
                          sanity: bool = False):
    """
    Multi-scale SAHI inference for the single-stage canthus model.

    Runs three scale tiers (close / mid / far) independently.
    All detections from all tiers are mapped back to full-frame
    pixel coordinates then merged per-class with NMS. The single
    highest-confidence box per class is returned.

    --- PHASE 1 CHANGE ---
    Each tier now applies its OWN confidence floor (from
    SAHI_CONFIGS) at inference time, AND every detection is checked
    against the global HARD_CONF_FLOOR before being added to the
    candidate pool. Both gates exist before NMS — cheaper (skips
    work downstream) and more correct (a lone ghost with no
    same-class competitor used to win by default; now it never
    enters the pool at all).

    Parameters
    ----------
    model   : loaded YOLO model
    bgr     : full frame in BGR uint8
    verbose : print per-slice hit details
    sanity  : run whole-frame sanity check before slicing

    Returns
    -------
    (left_pt, right_pt, left_conf, right_conf)
        Points are (x, y) float in full-frame pixels, or None if
        that class was not found in any tile.
    """
    prepped = _preprocess(bgr)
    h, w    = prepped.shape[:2]

    if sanity:
        _sanity_check_whole_frame(model, prepped)

    left_dets  = []   # list of (box_xyxy_fullframe, conf)
    right_dets = []
    total_slices = 0
    total_hits   = 0
    total_floored = 0

    for tier_idx, (sw, sh, overlap, upscale, tier_conf_floor) in enumerate(SAHI_CONFIGS):
        slices = _make_slices(w, h, sw, sh, overlap)
        total_slices += len(slices)

        # Run inference at the LOWER of the tier floor / hard floor so we
        # can still see (and log) borderline hits, but gate them below.
        # Using a slightly lower model-level conf than our final gate
        # avoids the model's internal NMS silently discarding candidates
        # we might still want to inspect when verbose.
        model_conf = min(tier_conf_floor, HARD_CONF_FLOOR)

        if verbose:
            print(f"[SAHI] tier={tier_idx}  "
                  f"tile={sw}x{sh}  overlap={overlap}  upscale={upscale}x  "
                  f"-> model input {int(sw*upscale)}x{int(sh*upscale)}  "
                  f"slices={len(slices)}  conf_floor={tier_conf_floor}")

        for (x1, y1, x2, y2) in slices:
            patch = prepped[y1:y2, x1:x2]
            if patch.size == 0:
                continue

            # Upscale gives the model more effective resolution for
            # tiny / far-away canthi without changing what the patch shows.
            if upscale != 1.0:
                patch_in = cv2.resize(
                    patch, None, fx=upscale, fy=upscale,
                    interpolation=cv2.INTER_LANCZOS4)
            else:
                patch_in = patch

            results = model(
                patch_in, imgsz=IMG_SIZE,
                conf=model_conf, verbose=False)[0]

            if results.boxes is None or len(results.boxes) == 0:
                continue

            boxes = results.boxes.xyxy.cpu().numpy()
            clss  = results.boxes.cls.cpu().numpy().astype(int)
            confs = results.boxes.conf.cpu().numpy()
            total_hits += len(boxes)

            if verbose:
                print(f"  HIT tier={tier_idx} "
                      f"slice ({x1},{y1})-({x2},{y2})  "
                      f"conf={confs.round(3)}  cls={clss.tolist()}")

            for box, cls_id, conf in zip(boxes, clss, confs):
                # --- PHASE 1 CHANGE: per-tier + hard floor gate ---
                # Reject here, before the detection ever reaches NMS.
                if conf < tier_conf_floor or conf < HARD_CONF_FLOOR:
                    total_floored += 1
                    continue

                # Map from upscaled-patch coords -> full-frame coords
                full_box = (
                    float(box[0] / upscale + x1),
                    float(box[1] / upscale + y1),
                    float(box[2] / upscale + x1),
                    float(box[3] / upscale + y1),
                )
                if cls_id == CLASS_LEFT:
                    left_dets.append((full_box, float(conf)))
                elif cls_id == CLASS_RIGHT:
                    right_dets.append((full_box, float(conf)))

    if verbose:
        print(f"[SAHI] Total slices across all tiers: {total_slices}  "
              f"raw hits: {total_hits}  floored out: {total_floored}  "
              f"left raw: {len(left_dets)}  right raw: {len(right_dets)}")

    # Per-class NMS + ghost-gap filter to collapse cross-tile/tier
    # duplicates and drop low-confidence outliers (see _nms_merge).
    left_dets  = _nms_merge(left_dets)
    right_dets = _nms_merge(right_dets)

    left_pt    = None
    right_pt   = None
    left_conf  = 0.0
    right_conf = 0.0

    if left_dets:
        (lx1, ly1, lx2, ly2), left_conf = max(left_dets, key=lambda d: d[1])
        left_pt = (float((lx1 + lx2) / 2.0),
                   float((ly1 + ly2) / 2.0))

    if right_dets:
        (rx1, ry1, rx2, ry2), right_conf = max(right_dets, key=lambda d: d[1])
        right_pt = (float((rx1 + rx2) / 2.0),
                    float((ry1 + ry2) / 2.0))

    # --- PHASE 1 CHANGE: geometric plausibility gate ---
    # Catches the case both NMS passes can miss: a real detection on
    # one side plus a spatially-separate ghost on the other side that
    # happens to have survived its own tier's confidence floor (e.g.
    # nose bridge misread as a canthus while the face is turning).
    if not _plausibility_check(left_pt, right_pt, w, h):
        # Demote to single canthus — keep whichever side has higher conf.
        if left_conf >= right_conf:
            right_pt   = None
            right_conf = 0.0
        else:
            left_pt   = None
            left_conf = 0.0

    return left_pt, right_pt, left_conf, right_conf


